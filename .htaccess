RewriteEngine On

# Force canonical host.
RewriteCond %{HTTP_HOST} !^arvadis\.store$ [NC]
RewriteRule ^ https://arvadis.store%{REQUEST_URI} [R=301,L]

# Redirect old HTML URLs to clean slugs.
RewriteRule ^index\.html$ / [R=301,L,NC]
RewriteRule ^moka\.html$ /Moka [R=301,L,NC]
RewriteRule ^saqr\.html$ /Saqr [R=301,L,NC]
RewriteRule ^projectors\.html$ /Projector [R=301,L,NC]
RewriteRule ^thank-you-cameras\.html$ /thank-you-cameras [R=301,L,NC]
RewriteRule ^thank-you-projectors\.html$ /thank-you-projectors [R=301,L,NC]

# Internal rewrites for clean slugs.
RewriteRule ^Moka/?$ /moka.html [L,NC]
RewriteRule ^Saqr/?$ /saqr.html [L,NC]
RewriteRule ^Projector/?$ /projectors.html [L,NC]
RewriteRule ^thank-you-cameras/?$ /thank-you-cameras.html [L,NC]
RewriteRule ^thank-you-projectors/?$ /thank-you-projectors.html [L,NC]
